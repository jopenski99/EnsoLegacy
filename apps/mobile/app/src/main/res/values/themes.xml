<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme. Compose draws the real UI; this keeps the launch window
         (and system bars) consistent before the first frame. The @color/enso_window
         resource resolves to light by default and dark via values-night. -->
    <style name="Theme.EnsoLegacy" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/enso_window</item>
        <item name="android:statusBarColor">@color/enso_window</item>
        <item name="android:navigationBarColor">@color/enso_window</item>
    </style>
</resources>
