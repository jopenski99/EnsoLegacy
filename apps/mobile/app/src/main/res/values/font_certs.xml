<?xml version="1.0" encoding="utf-8"?>
<!--
  Certificate fingerprints for the Google Mobile Services fonts provider.
  Required by ui-text-google-fonts at runtime to verify the provider before
  downloading Newsreader and Work Sans.

  TO FILL IN: In Android Studio, go to Resources > New > Font Resource File,
  choose "Downloadable" and search for "Newsreader". Studio will regenerate this
  file with the real GMS certificate strings. Until then the app falls back to
  the system serif/sans fonts gracefully.
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>

    <!-- Placeholder — replace with real cert strings via Android Studio font wizard. -->
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>placeholder_dev_cert</item>
    </string-array>

    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>placeholder_prod_cert</item>
    </string-array>
</resources>
